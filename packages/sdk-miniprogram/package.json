{
  "name": "@health-guard/sdk-miniprogram",
  "version": "0.3.0",
  "description": "HealthGuard SDK for mini program runtimes.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Claud-Lu/healthguard.git",
    "directory": "packages/sdk-miniprogram"
  },
  "homepage": "https://github.com/Claud-Lu/healthguard#readme",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --root ../.. packages/sdk-miniprogram/src/index.test.ts packages/sdk-miniprogram/src/bundle-boundary.test.ts"
  },
  "dependencies": {}
}
