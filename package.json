{
  "name": "healthguard",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hosted application health monitoring for H5 and mini program applications.",
  "license": "MIT",
  "packageManager": "yarn@1.22.21",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "yarn workspaces run build",
    "dev:dashboard": "yarn workspace @healthguard/dashboard dev",
    "dev:demo": "yarn workspace @healthguard/vue3-demo dev",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:server": "yarn workspace @healthguard/server dev",
    "lint": "eslint . --ext .ts,.tsx,.vue --max-warnings=0",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify": "^4.29.1",
    "nanoid": "^5.1.6",
    "pg": "^8.13.1",
    "vue": "^3.5.25",
    "vue-router": "4",
    "zod": "^3.25.76"
  }
}
